rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. GLOBAL SAFETY NET: Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. HELPER FUNCTIONS
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 3. VALIDATION HELPERS
    function isValidUserProfile(data) {
      // Use data.get() for defensive programming against missing fields during partial updates
      return data.get('full_name', '') is string && 
             data.get('email', '') is string &&
             (data.get('role', 'freelancer') in ['freelancer', 'client', 'admin']) &&
             (data.get('photo_url', '') is string);
    }

    // 4. COLLECTION RULES
    
    // Connection test document
    match /test/connection {
      allow read: if true;
    }
    
    // Users Collection
    match /users/{userId} {
      // Anyone signed in can view profiles (needed for Talents page)
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data) &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                        'full_name', 'bio', 'title', 'skills', 'hourly_rate', 
                        'location', 'socials', 'photo_url', 'last_updated', 
                        'is_new_user', 'role', 'is_premium'
                      ]);
    }

    // Jobs Collection
    match /jobs/{jobId} {
      allow read: if true; // Jobs are public
      allow create: if isSignedIn() && isVerified();
      allow update, delete: if isSignedIn() && resource.data.client_id == request.auth.uid;
    }

    // Proposals Collection
    match /proposals/{proposalId} {
      allow read: if isSignedIn() && (resource.data.freelancer_id == request.auth.uid || 
                     get(/databases/$(database)/documents/jobs/$(resource.data.job_id)).data.client_id == request.auth.uid);
      allow create: if isSignedIn() && isVerified();
      allow update: if isSignedIn() && (resource.data.freelancer_id == request.auth.uid || 
                       get(/databases/$(database)/documents/jobs/$(resource.data.job_id)).data.client_id == request.auth.uid);
    }

    // Messages Collection
    match /conversations/{convId}/messages/{msgId} {
      allow read, create: if isSignedIn() && (request.auth.uid in convId.split('_'));
    }
  }
}
